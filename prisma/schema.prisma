generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Roles {
  id    Int     @id(map: "roles_pkey") @default(autoincrement())
  name  String  @unique(map: "roles_name_key") @db.VarChar(50)
  users Users[]
}

model Sites {
  id        Int         @id(map: "sites_pkey") @default(autoincrement())
  name      String      @db.VarChar(255)
  domain    String      @unique(map: "sites_domain_key") @db.VarChar(255)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  userId    Int
  user      Users     @relation(fields: [userId], references: [id])

  posts BlogPosts[]
  projects  Projects[]
}

model Users {
  id           Int         @id(map: "users_pkey") @default(autoincrement())
  name         String      @db.VarChar(100)
  phoneNumber  String?     @db.VarChar(20)
  email        String      @unique(map: "users_email_key") @db.VarChar(255)
  password     String      @db.VarChar(255)
  companyName  String?     @db.VarChar(255)
  businessType String?     @db.VarChar(100)
  createdAt    DateTime?   @default(now()) @db.Timestamp(6)
  roleId       Int
  role         Roles       @relation(fields: [roleId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_role")

  sites        Sites[]
  posts    BlogPosts[]
  projects     Projects[]
}

model Projects {
  id          Int       @id(map: "projects_pkey") @default(autoincrement())
  name        String    @db.VarChar(255)
  description String
  type        String    @db.VarChar(100)
  startDate   DateTime  @db.Date
  dueDate     DateTime? @db.Date
  attachments String?
  createdAt   DateTime? @default(now()) @db.Timestamp(6)
  url         String?   @db.VarChar(50)

  siteId      Int
  sites       Sites     @relation(fields: [siteId], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "fk_site")

  userId      Int
  users       Users     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_user")
}

model BlogPosts {
  id            Int       @id(map: "blog_posts_pkey") @default(autoincrement())
  title         String    @db.VarChar(255)
  slug          String    @unique(map: "blog_posts_slug_key") @db.VarChar(255)
  author        String    @db.VarChar(100)
  content       String
  image         String?
  category      String?   @db.VarChar(100)
  status        String?   @default("draft") @db.VarChar(20)
  publishedDate DateTime? @db.Date
  createdAt     DateTime? @default(now()) @db.Timestamp(6)
  updatedAt     DateTime? @default(now()) @db.Timestamp(6)

  siteId        Int
  sites         Sites     @relation(fields: [siteId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_site")

  userId        Int
  users         Users     @relation(fields: [userId], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "fk_user")
}
